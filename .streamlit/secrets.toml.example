# Copy this file to secrets.toml and fill in your credentials.
# password_hash format: "<salt>$<pbkdf2-hmac-sha256-hex>"
# To generate a hash:
#   python3 -c "
#   import hashlib, binascii, os
#   salt = binascii.hexlify(os.urandom(16)).decode()
#   dk   = hashlib.pbkdf2_hmac('sha256', b'yourpassword', salt.encode(), 600000)
#   print(salt + '\$' + binascii.hexlify(dk).decode())
#   "

[auth]
username      = "admin"
password_hash = "<salt>$<pbkdf2-hmac-sha256-hex>"
